#!/bin/sh
# Guardrails companion: user-run authorization for ONE git push within 30 min.
# hooks/guard.py consumes the flag on the first allowed push (single-use).
set -e
cd "$(git rev-parse --show-toplevel)"
mkdir -p .claude
touch .claude/.allow-push
echo "guardrails: ONE git push authorized for 30 minutes (flag: .claude/.allow-push)"
